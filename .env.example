# Database Configuration
# For local development, use SQLite:
DATABASE_URL="file:./dev.db"

# For production (Railway, Vercel, etc.), use PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:port/database"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# For production, set to your actual domain:
# NEXTAUTH_URL="https://your-domain.com"

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Cloudinary Configuration (Optional - for image uploads)
# Get your credentials from: https://console.cloudinary.com/
# Cloud name (required)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# For unsigned uploads (easier setup, recommended for development):
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# For signed uploads (more secure, recommended for production):
NEXT_PUBLIC_CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Note: You can use either unsigned (upload preset) or signed (API key + secret) uploads
# Unsigned is easier to set up but less secure
# Signed provides better control and security
# For signed uploads, API Key must be NEXT_PUBLIC_ so the widget can access it
